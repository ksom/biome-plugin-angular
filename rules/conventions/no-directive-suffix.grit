// Limitation: GritQL cannot match @Directive\nclass as one unit,
// so this matches ANY class ending in "Directive" (heuristic).
// In Angular projects this is accurate; may false-positive in non-Angular code.
language js

`class $name { $_ }` where {
  $name <: r".*Directive$",
  register_diagnostic(span = $name, message = "Angular v20+: remove the 'Directive' suffix from class names. Name classes after what they represent.", severity = "warn")
}

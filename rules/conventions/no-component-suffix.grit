// Limitation: GritQL cannot match @Component\nclass as one unit,
// so this matches ANY class ending in "Component" (heuristic).
// In Angular projects this is accurate; may false-positive in non-Angular code.
language js

`class $name { $_ }` where {
  $name <: r".*Component$",
  register_diagnostic(span = $name, message = "Angular v20+: remove the 'Component' suffix from class names. Name classes after what they represent.", severity = "warn")
}

language js

or {
  `@Input($alias)` where {
    $alias <: r"^['\"].*['\"]$",
    register_diagnostic(span = $alias, message = "Avoid renaming @Input() properties. Use the property name as the public API.")
  },

  `@Input({ $opts })` where {
    $opts <: contains `alias: $_`,
    register_diagnostic(span = $opts, message = "Avoid renaming @Input() properties. Use the property name as the public API.")
  }
}

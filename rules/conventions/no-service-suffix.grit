// Limitation: GritQL cannot match @Injectable\nclass as one unit,
// so this matches ANY class ending in "Service" (heuristic).
// In Angular projects this is accurate; may false-positive in non-Angular code.
language js

`class $name { $_ }` where {
  $name <: r".*Service$",
  register_diagnostic(span = $name, message = "Angular v20+: remove the 'Service' suffix. Use a descriptive name (Store, Api, Client, Facade…).", severity = "warn")
}

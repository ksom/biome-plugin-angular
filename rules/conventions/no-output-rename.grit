language js

or {
  `@Output($alias)` where {
    $alias <: r"^['\"].*['\"]$",
    register_diagnostic(span = $alias, message = "Avoid renaming @Output() properties. Use the property name as the event name.")
  },

  `@Output({ $opts })` where {
    $opts <: contains `alias: $_`,
    register_diagnostic(span = $opts, message = "Avoid renaming @Output() properties. Use the property name as the event name.")
  }
}

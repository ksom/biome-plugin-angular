// Limitation: GritQL cannot match @Injectable/@Component\nclass as one unit,
// so this matches ANY constructor with access-modifier params (heuristic).
// In Angular projects this is accurate; may false-positive in non-Angular code.
language js

`constructor($params) { $_ }` where {
  $params <: contains or { `private`, `protected`, `public`, `readonly` },
  register_diagnostic(span = $params, message = "Prefer inject() over constructor-based dependency injection (Angular 14+).", severity = "warn")
}
